# NC AI SDK — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are optional unless noted.

# ── Server configuration ──────────────────────────────────────────

# Port for nc serve sdk/nc_ai_api.nc (default: 8092)
NC_AI_SDK_PORT=8092

# Host to bind to (default: 127.0.0.1 — localhost only)
# Set to 0.0.0.0 to expose externally (put behind a reverse proxy with TLS)
NC_AI_SDK_HOST=127.0.0.1

# ── NC Engine ─────────────────────────────────────────────────────

# Path to the nc binary (default: auto-detected from PATH)
# NC_BIN=/usr/local/bin/nc

# Path to the trained AI model weights (default: auto-detected)
# NC_MODEL_PATH=/path/to/nc_ai_model_prod.bin

# Path to the BPE tokenizer vocabulary (default: auto-detected)
# NC_TOKENIZER_PATH=/path/to/nc_ai_model_prod.nctok

# ── Generation settings ───────────────────────────────────────────

# Maximum response tokens for AI generation (default: 512)
# NC_MAX_TOKENS=512

# Temperature for sampling — 0.0 = deterministic, 1.0 = creative (default: 0.7)
# NC_TEMPERATURE=0.7

# ── External LLM bridge (optional) ───────────────────────────────
# When set, the SDK can forward prompts to an external LLM for richer generation.
# If not set, all generation is local template-based (default behavior).

# External LLM API endpoint (OpenAI-compatible)
# NC_AI_BRIDGE_URL=https://api.openai.com/v1

# API key for the external LLM bridge
# WARNING: Never commit this value. Use environment variables or a secrets manager.
# NC_AI_BRIDGE_KEY=sk-...

# Model to use on the external bridge (default: gpt-4o-mini)
# NC_AI_BRIDGE_MODEL=gpt-4o-mini

# ── Rate limiting ─────────────────────────────────────────────────

# Maximum requests per minute per IP (default: 100)
# NC_RATE_LIMIT=100

# Maximum request body size in bytes (default: 65536 = 64 KB)
# NC_MAX_BODY=65536

# ── Logging ───────────────────────────────────────────────────────

# Log level: debug | info | warn | error (default: info)
# NC_LOG_LEVEL=info

# Log format: text | json (default: text)
# NC_LOG_FORMAT=text

# ── Development ───────────────────────────────────────────────────

# Set to 1 to enable verbose NC engine debug output
# NC_DEBUG=0

# Set to 1 to allow file system writes from NC scripts (required for training)
# NC_ALLOW_FILE_WRITE=0

# Set to 1 to allow shell exec calls from NC scripts
# NC_ALLOW_EXEC=0
